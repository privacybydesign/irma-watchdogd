checkcertificateexpiry:
    - https://privacybydesign.foundation
    - https://metrics.privacybydesign.foundation
checkatumservers:
    - https://keyshare.privacybydesign.foundation/atumd
healthchecks:
    - requesturl: https://privacybydesign.foundation
      responsebodycontains: "De stichting Privacy by Design creëert en onderhoudt gratis open source software waarbij de privacy van de gebruiker voorop staat."
bindaddr: ':8079'
interval: 5m

# Number of consecutive check cycles an issue must be observed before it is
# reported to Slack/webhooks. Higher values suppress transient blips (a host
# briefly unreachable) at the cost of slower alerting on real outages.
# Defaults to 3. Set to 1 to alert on the first failed cycle (old behaviour).
failurethreshold: 3

webhooks:
    - https://example.com/?message=%s
